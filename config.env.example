# SenseCap M1 Gateway — User Configuration
# Copy this file to config.env and edit before first boot.
# All settings can also be configured via the web UI after boot.

# LoRa Band / Region
# Options: au_915_928 | us_902_928 | eu_863_870 | as_923_1 | as_923_2 |
#          in_865_867 | kr_920_923 | ru_864_870 | cn_470_510
BAND=au_915_928

# Tailscale auth key (optional — one-time use key from tailscale.com/settings/keys)
# Leave blank to skip Tailscale on first boot.
# Can be configured later by running: tailscale up --authkey=<key> --hostname=$(hostname)
# The key is automatically scrubbed from this file after first use.
TAILSCALE_AUTHKEY=

# Location (used for fake GPS — no GPS hardware on SenseCap M1)
# Required for Helium Proof of Coverage. Set your actual install location.
GPS_LATITUDE=
GPS_LONGITUDE=
GPS_ALTITUDE=0

# System timezone (tz database name, e.g. Etc/UTC, Australia/Perth, America/Chicago)
# Must exist as a file under /usr/share/zoneinfo/.
# Defaults to Etc/UTC if unset or invalid.
TIMEZONE=Etc/UTC

# Optional: override hostname (default: sensecap-<last6mac>)
HOSTNAME=
